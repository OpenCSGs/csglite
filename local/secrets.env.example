# Copy to secrets.env and set your token (file is gitignored).
# GitLab: https://git-devops.opencsg.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN="glpat-xxxxxxxxxxxxxxxxxxxx"

# StarHub OSS mirror for Claude Code artifacts (gitignored in local/secrets.env).
STARHUB_OSS_ACCESS_KEY_ID="your-access-key-id"
STARHUB_OSS_ACCESS_KEY_SECRET="your-access-key-secret"
STARHUB_OSS_ENDPOINT="oss-cn-beijing.aliyuncs.com"
STARHUB_OSS_REGION="cn-beijing"
STARHUB_OSS_PUBLIC_BUCKET="your-public-bucket"
STARHUB_CLAUDE_DIST_PREFIX="claude-code-releases"
STARHUB_CLAUDE_DIST_BASE_URL="https://${STARHUB_OSS_PUBLIC_BUCKET}.${STARHUB_OSS_ENDPOINT}/${STARHUB_CLAUDE_DIST_PREFIX}"
STARHUB_OPEN_CODE_DIST_PREFIX="open-code-releases"
STARHUB_OPEN_CODE_DIST_BASE_URL="https://${STARHUB_OSS_PUBLIC_BUCKET}.${STARHUB_OSS_ENDPOINT}/${STARHUB_OPEN_CODE_DIST_PREFIX}"
STARHUB_CODEX_DIST_PREFIX="codex-releases"
STARHUB_CODEX_DIST_BASE_URL="https://${STARHUB_OSS_PUBLIC_BUCKET}.${STARHUB_OSS_ENDPOINT}/${STARHUB_CODEX_DIST_PREFIX}"
STARHUB_CODEX_APP_DIST_PREFIX="codex-app-releases"
STARHUB_CODEX_APP_DIST_BASE_URL="https://${STARHUB_OSS_PUBLIC_BUCKET}.${STARHUB_OSS_ENDPOINT}/${STARHUB_CODEX_APP_DIST_PREFIX}"
